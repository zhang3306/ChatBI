# ChatBI - Smart Home AI Operations System
# https://github.com/zhang3306/chatbi
#
# Setup:
#   1. cp .env.example .env
#   2. Fill in your DeepSeek API Key
#   3. python run.py --seed --index --ui

DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Data scale factor for mock data (1.0 = ~46 million rows)
# SEED_SCALE=0.01
